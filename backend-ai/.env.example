# =============================================================================
# Meridian Backend AI (FastAPI + LangGraph) — copy to .env and fill in your values
# =============================================================================

# App
ENVIRONMENT=development
PORT=8001

# --- Bright Data (web intelligence) ---
# One account gives access to all tools. See docs/ENV_SETUP.md Step 1.
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
BRIGHTDATA_SERP_ZONE=your_serp_zone_name
BRIGHTDATA_SERP_USERNAME=brd-customer-xxx-zone-your_serp_zone
BRIGHTDATA_SERP_PASSWORD=your_serp_password
BRIGHTDATA_WEB_UNLOCKER_USERNAME=brd-customer-xxx-zone-your_unlocker_zone
BRIGHTDATA_WEB_UNLOCKER_PASSWORD=your_unlocker_password
BRIGHTDATA_SCRAPING_BROWSER_ENDPOINT=wss://brd-customer-xxx-zone-your_browser_zone:password@brd.superproxy.io:9222
BRIGHTDATA_RESIDENTIAL_PROXY_HOST=brd.superproxy.io
BRIGHTDATA_RESIDENTIAL_PROXY_PORT=22225
BRIGHTDATA_RESIDENTIAL_USERNAME=brd-customer-xxx-zone-your_residential_zone
BRIGHTDATA_RESIDENTIAL_PASSWORD=your_residential_password
BRIGHTDATA_MCP_SERVER_URL=https://mcp.brightdata.com/sse

# --- AI/ML API (aimlapi.com) — primary intelligence layer ---
AIMLAPI_API_KEY=your_aimlapi_api_key_here
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o
AIMLAPI_REASONING_MODEL=openai/o4-mini

# --- Featherless AI (featherless.ai) — open-source serverless inference (fallback) ---
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# --- Speechmatics — speech-to-text for audio evidence ---
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here
SPEECHMATICS_URL=https://asr.api.speechmatics.com/v2

# --- Groq — fast preprocessing (classification, translation) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Infrastructure (local Docker | prod: Supabase / Upstash / Qdrant Cloud) ---
# DATABASE_URL uses the async driver prefix (postgresql+asyncpg://).
# Local:    postgresql+asyncpg://meridian_user:meridian_pass@localhost:5432/meridian_db
# Supabase: postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://meridian_user:meridian_pass@localhost:5432/meridian_db
# Local: redis://localhost:6379  |  Upstash: rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=redis://localhost:6379
# Local: http://localhost:6333  |  Qdrant Cloud: https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Backend URL (for job-completion callbacks) ---
BACKEND_URL=http://localhost:8000

# --- Shared secret for callbacks to the Hono backend (must match backend) ---
INTERNAL_API_SECRET=change_me_to_a_long_random_string
