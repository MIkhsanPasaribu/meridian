# =============================================================================
# Meridian Backend (Hono) — copy to .env and fill in your values
# =============================================================================

# App
NODE_ENV=development
PORT=8000

# --- Database (Supabase PostgreSQL) ---
# DATABASE_URL: pooled/runtime connection (Supabase transaction pooler, port 6543).
#   Append ?pgbouncer=true&connection_limit=1 so Prisma disables prepared statements.
# DIRECT_URL: non-pooled connection for Prisma Migrate (Supabase session pooler, port 5432).
# Local dev: point both at your local Postgres (same value is fine).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Local example:
# DATABASE_URL=postgresql://meridian_user:meridian_pass@localhost:5432/meridian_db
# DIRECT_URL=postgresql://meridian_user:meridian_pass@localhost:5432/meridian_db

# --- Redis (Upstash in prod, local Docker in dev) ---
# Local: redis://localhost:6379  |  Upstash: rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# --- JWT (generate 32+ char secrets) ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend URL (CORS allow-list) ---
FRONTEND_URL=http://localhost:3000

# --- Object Storage (S3-compatible: local MinIO / Supabase Storage / AWS S3) ---
# Local MinIO: MINIO_ENDPOINT=localhost, MINIO_PORT=9000, MINIO_USE_SSL=false
# Cloud S3:    MINIO_ENDPOINT=<s3-host>, MINIO_PORT=443, MINIO_USE_SSL=true
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=meridian_admin
MINIO_SECRET_KEY=meridian_minio_pass
MINIO_BUCKET=meridian-evidence
MINIO_REGION=us-east-1

# --- Email (Nodemailer) — optional for demo ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@meridian.ai

# --- Slack — optional ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Backend AI service URL (for proxying AI/transcription requests) ---
BACKEND_AI_URL=http://localhost:8001

# --- Shared secret for AI worker -> backend callbacks (must match backend-ai) ---
INTERNAL_API_SECRET=change_me_to_a_long_random_string
