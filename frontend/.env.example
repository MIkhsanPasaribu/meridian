# =============================================================================
# Meridian Frontend (Next.js) — copy to .env.local and fill in your values
# =============================================================================

# Backend API base URL (no trailing slash).
# Local: http://localhost:8000  |  Production: https://<your-backend-domain>
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time updates.
# Local: ws://localhost:8000  |  Production: wss://<your-backend-domain>
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Mapbox public token for the world risk heatmap (starts with pk.).
# Get one at https://account.mapbox.com (scopes: styles:read, tiles:read)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
